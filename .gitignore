# CRAFT ENVIRONMENT
.env.php
.env.sh
.env

# COMPOSER
/vendor
# This is a library/plugin — consumers never use our lock file, and committing
# it only created stale-lock churn (and dependabot lock-bump noise). Security is
# enforced by `composer audit` in CI against the composer.json constraints.
composer.lock

# BUILD FILES
/bower_components/*
/node_modules/*
/build/*
/yarn-error.log

# MISC FILES
.cache
.DS_Store
.idea
.project
.settings
*.esproj
*.sublime-workspace
*.sublime-project
*.tmproj
*.tmproject
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
config.codekit3
prepros-6.config
